<script>
(function(){
  function showView(target){
    if(!target) return;

    var targetView = document.getElementById('view-' + target);
    if(!targetView && target.indexOf('view-') === 0){
      targetView = document.getElementById(target);
      target = target.replace(/^view-/, '');
    }
    if(!targetView) return;

    document.querySelectorAll('.view').forEach(function(view){
      view.classList.remove('active');
      view.style.display = 'none';
    });

    targetView.classList.add('active');
    targetView.style.display = 'block';

    document.querySelectorAll('.pill').forEach(function(pill){
      pill.classList.toggle('active', pill.getAttribute('data-target') === target);
    });

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function wireClicks(){
    document.querySelectorAll('[data-target]').forEach(function(el){
      el.style.cursor = 'pointer';
      el.addEventListener('click', function(e){
        var target = el.getAttribute('data-target');
        if(target && document.getElementById('view-' + target)){
          e.preventDefault();
          showView(target);
        }
      });
    });

    document.querySelectorAll('a[href^="#view-"]').forEach(function(el){
      el.addEventListener('click', function(e){
        var target = el.getAttribute('href').replace('#view-','');
        if(document.getElementById('view-' + target)){
          e.preventDefault();
          showView(target);
        }
      });
    });

    document.querySelectorAll('a[href="#"]').forEach(function(el){
      if(el.getAttribute('data-target')){
        el.addEventListener('click', function(e){ e.preventDefault(); });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function(){
    document.querySelectorAll('.view').forEach(function(view){
      if(view.classList.contains('active')){
        view.style.display = 'block';
      } else {
        view.style.display = 'none';
      }
    });
    wireClicks();

    if(location.hash && location.hash.indexOf('#view-') === 0){
      showView(location.hash.replace('#view-',''));
    }
  });

  window.showView = showView;
})();
</script>

<script>
(function(){
  function textOnly(el){ return (el ? el.textContent : '').replace(/\s+/g,' ').trim(); }
  function getTitle(view){
    var h = view.querySelector('h1, h2, h3');
    return h ? textOnly(h) : view.id.replace(/^view-/,'').replace(/-/g,' ');
  }
  function getSummary(view){
    var p = view.querySelector('p');
    return p ? textOnly(p).slice(0,180) : 'Open this toolkit section.';
  }
  function highlight(text, query){
    if(!query) return text;
    var safe = query.replace(/[.*+?^${}()|[\]\]/g, '\$&');
    return text.replace(new RegExp('('+safe+')','ig'), '<mark class="search-hit">$1</mark>');
  }
  function runSearch(){
    var input = document.getElementById('siteSearch');
    var results = document.getElementById('searchResults');
    if(!input || !results) return;
    var q = input.value.trim().toLowerCase();
    results.innerHTML = '';
    if(q.length < 2){ results.classList.remove('active'); return; }

    var matches = Array.from(document.querySelectorAll('.view')).map(function(view){
      var title = getTitle(view);
      var summary = getSummary(view);
      var haystack = textOnly(view).toLowerCase();
      return {view:view, title:title, summary:summary, score:(title.toLowerCase().includes(q)?3:0)+(summary.toLowerCase().includes(q)?2:0)+(haystack.includes(q)?1:0)};
    }).filter(function(item){ return item.score > 0; })
      .sort(function(a,b){ return b.score - a.score || a.title.localeCompare(b.title); })
      .slice(0,12);

    results.classList.add('active');
    var heading = document.createElement('div');
    heading.className = 'search-results-title';
    heading.textContent = matches.length ? 'Search results' : 'No matching sections found';
    results.appendChild(heading);

    if(!matches.length){
      var empty = document.createElement('div');
      empty.className = 'search-empty';
      empty.textContent = 'Try searching for pipeline, bid, pricing, win loss, region, CRM, training, or contacts.';
      results.appendChild(empty);
      return;
    }

    matches.forEach(function(item){
      var target = item.view.id.replace(/^view-/,'');
      var a = document.createElement('a');
      a.href = '#view-' + target;
      a.className = 'search-result-item';
      a.setAttribute('data-target', target);
      a.innerHTML = '<strong>' + highlight(item.title, q) + '</strong><span>' + highlight(item.summary, q) + '</span>';
      a.addEventListener('click', function(e){
        e.preventDefault();
        results.classList.remove('active');
        input.value = '';
        if(window.showView){ window.showView(target); }
        else { location.hash = '#view-' + target; }
      });
      results.appendChild(a);
    });
  }

  document.addEventListener('DOMContentLoaded', function(){
    var input = document.getElementById('siteSearch');
    var clear = document.getElementById('clearSearch');
    var results = document.getElementById('searchResults');
    if(input){ input.addEventListener('input', runSearch); }
    if(clear){ clear.addEventListener('click', function(){ input.value=''; if(results){results.classList.remove('active');results.innerHTML='';} input.focus(); }); }
    document.addEventListener('click', function(e){
      if(results && !e.target.closest('.search-shell')) results.classList.remove('active');
    });
  });
})();
</script>

</body>
</html>
