<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>CTM Global Sales Toolkit Hub - Corporate Mockup</title>
<style>
  :root{
    --ctm-navy:#003b49;
    --ctm-teal:#007c94;
    --ctm-green:#76bc43;
    --ink:#102033;
    --muted:#667085;
    --bg:#eef3f8;
    --card:#ffffff;
    --line:#d8e1ea;
    --soft:#f8fbfd;
    --shadow:0 18px 45px rgba(16,32,51,.10);
    --shadow-sm:0 8px 22px rgba(16,32,51,.08);
    --radius:24px;
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    margin:0;
    font-family:"Aptos","Segoe UI",Arial,sans-serif;
    color:var(--ink);
    background:
      radial-gradient(circle at top left,rgba(0,124,148,.20),transparent 30%),
      radial-gradient(circle at top right,rgba(118,188,67,.14),transparent 25%),
      linear-gradient(180deg,#f7fafc 0%,#eef3f8 42%,#f8fafc 100%);
    min-height:100vh;
  }
  a{color:inherit}
  .shared-banner{
    background:linear-gradient(90deg,#002f3a,#005568,#007c94);
    color:#fff;
    padding:10px 7vw;
    position:relative;
    font-size:13px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:18px;
    box-shadow:0 2px 12px rgba(0,0,0,.12);
  }
  .shared-banner strong{font-size:15px;margin-right:8px;letter-spacing:.02em}
  .shared-banner a{color:#fff;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.6)}
  .edit-pill{
    background:rgba(255,255,255,.16);
    color:#fff!important;
    border:1px solid rgba(255,255,255,.32)!important;
    border-radius:999px;
    padding:8px 14px;
    font-weight:700;
    text-decoration:none!important;
    backdrop-filter:blur(12px);
    white-space:nowrap;
  }

  .site-header{
    background:rgba(255,255,255,.92);
    border-bottom:1px solid rgba(216,225,234,.88);
    padding:18px 7vw 16px;
    display:grid;
    grid-template-columns:minmax(280px,340px) 1fr;
    gap:24px;
    align-items:start;
    position:sticky;
    top:0;
    z-index:20;
    backdrop-filter:blur(18px);
    box-shadow:0 10px 28px rgba(16,32,51,.06);
  }
  .brand{display:flex;gap:16px;align-items:center;min-width:0;padding-top:4px}
  .ctm-box{
    width:56px;height:56px;border-radius:18px;
    background:linear-gradient(135deg,var(--ctm-navy),var(--ctm-teal));
    color:#fff;display:flex;align-items:center;justify-content:center;
    font-size:22px;font-weight:900;letter-spacing:-1px;
    box-shadow:0 12px 25px rgba(0,59,73,.25);
  }
  .site-name{font-size:22px;font-weight:850;margin-bottom:3px;color:#082536;letter-spacing:-.02em}
  .site-sub{color:var(--muted);line-height:1.35;font-size:13px}
  .pills{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
    gap:9px;
    padding:0;
    overflow:visible;
  }
  .pill{
    display:flex;align-items:center;justify-content:center;gap:8px;
    background:#fff;color:#344054;
    padding:10px 12px;border-radius:14px;text-decoration:none;font-size:13px;font-weight:750;
    border:1px solid var(--line);cursor:pointer;white-space:normal;text-align:center;min-height:44px;
    box-shadow:0 2px 8px rgba(16,32,51,.04);
    transition:transform .18s ease, box-shadow .18s ease, background .18s ease, color .18s ease, border-color .18s ease;
  }
  .pill:hover{transform:translateY(-1px);border-color:#a8bdcc;box-shadow:var(--shadow-sm);background:#f8fbfd}
  .pill.active{background:linear-gradient(135deg,var(--ctm-navy),var(--ctm-teal));color:#fff;border-color:transparent;box-shadow:0 10px 22px rgba(0,124,148,.22)}


  .search-shell{
    grid-column:1 / -1;
    display:grid;
    grid-template-columns:minmax(220px,1fr) auto;
    gap:10px;
    align-items:center;
    background:#f8fbfd;
    border:1px solid var(--line);
    border-radius:18px;
    padding:10px 12px;
    box-shadow:0 2px 10px rgba(16,32,51,.04);
  }
  .search-box{
    width:100%;border:0;outline:0;background:transparent;color:var(--ink);
    font:600 15px "Segoe UI",Arial,sans-serif;padding:10px 8px;
  }
  .search-box::placeholder{color:#7b8794;font-weight:600}
  .search-clear{
    border:1px solid var(--line);background:#fff;color:#344054;border-radius:999px;
    padding:9px 14px;font-weight:800;cursor:pointer;
  }
  .search-clear:hover{background:#eef8fb;border-color:#b9dce4}
  .search-results{
    grid-column:1 / -1;display:none;background:#fff;border:1px solid var(--line);border-radius:18px;
    padding:14px;box-shadow:var(--shadow-sm);max-height:360px;overflow:auto;
  }
  .search-results.active{display:block}
  .search-results-title{font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:900;margin:0 0 10px}
  .search-result-item{
    display:block;text-decoration:none;color:var(--ink);border:1px solid var(--line);border-radius:14px;
    padding:12px 14px;margin:8px 0;background:#fbfdff;
  }
  .search-result-item:hover{border-color:#a8bdcc;background:#f3f8fb}
  .search-result-item strong{display:block;color:#082536;margin-bottom:4px}
  .search-result-item span{display:block;color:var(--muted);font-size:13px;line-height:1.4}
  .search-empty{color:var(--muted);padding:8px 4px;font-weight:700}
  mark.search-hit{background:#fff4c2;color:#0b1f35;border-radius:4px;padding:0 2px}

  main{max-width:1560px;margin:0 auto;padding:34px 7vw 72px}
  .hero{
    background:
      linear-gradient(135deg,rgba(0,59,73,.96),rgba(0,86,104,.92) 48%,rgba(0,124,148,.92)),
      radial-gradient(circle at 78% 20%,rgba(118,188,67,.42),transparent 26%);
    color:#fff;border-radius:32px;padding:54px 50px;margin-bottom:30px;min-height:292px;
    box-shadow:var(--shadow);position:relative;overflow:hidden;
    border:1px solid rgba(255,255,255,.18);
  }
  .hero:before{
    content:"";position:absolute;inset:18px;border:1px solid rgba(255,255,255,.10);border-radius:26px;pointer-events:none;
  }
  .hero:after{
    content:"";position:absolute;right:-90px;top:-120px;width:500px;height:500px;border-radius:50%;
    background:radial-gradient(circle,rgba(255,255,255,.20),rgba(255,255,255,.04) 42%,transparent 68%);
  }
  .eyebrow{letter-spacing:.42em;font-size:12px;opacity:.9;text-transform:uppercase;margin-bottom:20px;font-weight:850;position:relative;z-index:1}
  h1{font-size:clamp(34px,4vw,56px);line-height:1.02;margin:0 0 20px;letter-spacing:-.045em;position:relative;z-index:1}
  .hero p{max-width:960px;font-size:18px;line-height:1.65;margin:0 0 28px;color:rgba(255,255,255,.90);position:relative;z-index:1}
  .owner{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.14);color:#fff;border:1px solid rgba(255,255,255,.22);border-radius:999px;padding:12px 18px;font-size:14px;font-weight:750;position:relative;z-index:1;backdrop-filter:blur(10px)}
  .owner:before{content:"●";color:var(--ctm-green);font-size:12px}

  .step-grid,.tile-grid,.quick-row,.three-grid,.bid-section-grid{display:grid;gap:18px}
  .step-grid{grid-template-columns:repeat(5,1fr);margin:0 0 30px}
  .tile-grid{grid-template-columns:repeat(4,1fr)}
  .quick-row{grid-template-columns:repeat(4,1fr)}
  .three-grid{grid-template-columns:repeat(3,1fr)}
  .bid-section-grid{grid-template-columns:repeat(5,1fr)}

  .step-card,.tile,.quick-link,.region-tile,.content-card,.bid-card,.metric-card,.stage-card,.question-card,.wl-debrief-wrap,.wl-question-card,.wl-step{
    background:rgba(255,255,255,.94);
    border:1px solid rgba(216,225,234,.95);
    border-radius:var(--radius);
    box-shadow:0 8px 25px rgba(16,32,51,.06);
  }
  .step-card,.tile,.quick-link,.region-tile,.bid-card{text-decoration:none;color:var(--ink);display:block;cursor:pointer;position:relative;overflow:hidden;transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease,background .18s ease}
  .step-card:after,.tile:after,.region-tile:after,.bid-card:after{
    content:"";position:absolute;inset:auto -30% -45% auto;width:145px;height:145px;border-radius:50%;background:rgba(0,124,148,.08);transition:.18s ease;
  }
  .step-card{min-height:138px;padding:28px 26px}
  .step-card:hover,.tile:hover,.region-tile:hover,.quick-link:hover,.bid-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:#b6cad8;background:#fff}
  .step-card:hover:after,.tile:hover:after,.region-tile:hover:after,.bid-card:hover:after{transform:scale(1.12);background:rgba(118,188,67,.14)}
  .step-card .num{color:var(--ctm-teal);font-size:26px;font-weight:900;letter-spacing:.08em;margin-bottom:18px}
  .step-card h3{margin:0;font-size:18px;line-height:1.35;color:#092b3a;position:relative;z-index:1}

  .content-card{padding:28px 32px;margin-bottom:28px;backdrop-filter:blur(10px)}
  .content-card h2{margin:0 0 14px;color:#082536;font-size:25px;letter-spacing:-.025em}
  .content-card p,.content-card li{color:#344054;line-height:1.68}
  .content-card ul{margin:0;padding-left:20px}
  .content-card b{color:#082536}

  .tile-section{margin-top:34px}
  .section-head{display:flex;align-items:end;justify-content:space-between;gap:18px;margin-bottom:18px}
  .section-head h2{margin:0;font-size:30px;color:#082536;letter-spacing:-.035em}
  .section-head p{margin:0;color:var(--muted)}

  .tile{padding:24px;min-height:170px;display:flex;flex-direction:column;justify-content:space-between}
  .tile-top{display:flex;gap:16px;align-items:flex-start;position:relative;z-index:1}
  .circle{width:46px;height:46px;border-radius:16px;background:linear-gradient(135deg,#e9f8fb,#eef8e9);color:var(--ctm-teal);display:flex;align-items:center;justify-content:center;font-weight:900;flex:0 0 auto;border:1px solid #d6e9ee}
  .tile h3{margin:0 0 8px;font-size:19px;color:#082536;letter-spacing:-.015em}
  .tile p{margin:0;color:var(--muted);line-height:1.48;font-size:14px}
  .arrow{align-self:flex-end;color:var(--ctm-teal);font-weight:900;font-size:26px;margin-top:16px;position:relative;z-index:1}

  .region-tile{padding:30px;min-height:185px;position:relative;overflow:hidden}
  .region-tile:before{content:"";position:absolute;right:24px;top:24px;width:38px;height:38px;border-radius:14px;background:linear-gradient(135deg,var(--ctm-teal),var(--ctm-green));opacity:.18}
  .region-tile h3{margin:0 0 10px;font-size:26px;color:#082536;letter-spacing:-.035em;position:relative;z-index:1}
  .region-tile p{margin:0;color:var(--muted);line-height:1.55;position:relative;z-index:1}

  .bid-card{padding:26px;min-height:205px;border-top:0}
  .bid-card:before{content:"";position:absolute;left:0;right:0;top:0;height:7px;background:linear-gradient(90deg,var(--ctm-teal),var(--ctm-green))}
  .bid-card:nth-child(2):before{background:linear-gradient(90deg,var(--ctm-green),#a7d878)}
  .bid-card h3{margin:14px 0 10px;font-size:21px;color:#082536;letter-spacing:-.02em;position:relative;z-index:1}
  .bid-card p{margin:0;color:#344054;line-height:1.55;font-size:15px;position:relative;z-index:1}
  .bid-num{color:var(--ctm-teal);font-size:28px;font-weight:900;letter-spacing:.08em;position:relative;z-index:1}

  .quick-link{padding:18px 20px;font-weight:800;border-radius:18px;background:#fff;color:#12354a;display:flex;justify-content:space-between;align-items:center;transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease,background .18s ease}
  .quick-link:hover{background:linear-gradient(135deg,#fff,#eef8fb);border-color:#9fc8d4}

  .backtop{display:inline-flex;align-items:center;gap:8px;margin-top:16px;color:var(--ctm-teal);font-weight:850;text-decoration:none;cursor:pointer;border:1px solid #c9e4ea;background:#eef8fb;border-radius:999px;padding:10px 14px}
  .backtop:hover{background:#e7f4f7}
  footer{color:var(--muted);padding:24px 7vw 40px;text-align:center}

  .dashboard-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-bottom:22px}
  .metric-card{padding:24px;background:linear-gradient(180deg,#fff,#fbfdfe)}
  .metric-label{color:var(--muted);font-size:12px;margin-bottom:10px;font-weight:900;text-transform:uppercase;letter-spacing:.10em}
  .metric-value{font-size:40px;font-weight:950;color:#082536;margin-bottom:6px;letter-spacing:-.04em}
  .metric-note{color:#344054;line-height:1.45;font-size:14px}
  .pipeline-board{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin:22px 0}
  .stage-card{padding:18px;border-top:0;position:relative;overflow:hidden}
  .stage-card:before{content:"";display:block;width:48px;height:5px;border-radius:999px;background:var(--ctm-teal);margin-bottom:14px}
  .stage-card:nth-child(2):before{background:#4aa7b6}.stage-card:nth-child(3):before{background:var(--ctm-green)}.stage-card:nth-child(4):before{background:#f0b429}.stage-card:nth-child(5):before{background:#ec7a32}.stage-card:nth-child(6):before{background:#667085}
  .stage-card h3{margin:0 0 8px;font-size:16px;color:#082536}.stage-card p{margin:0;color:var(--muted);font-size:13px;line-height:1.45}
  .dashboard-table{width:100%;border-collapse:separate;border-spacing:0;background:#fff;border:1px solid var(--line);border-radius:22px;overflow:hidden;box-shadow:var(--shadow-sm)}
  .dashboard-table th,.dashboard-table td{text-align:left;padding:15px 16px;border-bottom:1px solid var(--line);font-size:14px;vertical-align:top}
  .dashboard-table th{background:#f5f9fc;color:#344054;font-size:12px;text-transform:uppercase;letter-spacing:.08em;font-weight:900}
  .dashboard-table tr:last-child td{border-bottom:none}
  .dashboard-table tbody tr:hover{background:#fbfdff}
  .stage-pill{display:inline-block;border-radius:999px;padding:6px 10px;font-weight:850;font-size:12px;background:#eaf7e7;color:#2f6f22;white-space:nowrap}
  .risk-pill{display:inline-block;border-radius:999px;padding:6px 10px;font-weight:850;font-size:12px;background:#fff4e5;color:#a15c00;white-space:nowrap}
  .owner-tag{font-weight:850;color:#082536}
  .questionnaire{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:18px}
  .question-card{padding:23px;border-left:0;position:relative;overflow:hidden}
  .question-card:before{content:"";position:absolute;left:0;top:0;bottom:0;width:6px;background:var(--ctm-teal)}
  .question-card:nth-child(2):before{background:var(--ctm-green)}
  .question-card:nth-child(3):before{background:#f0b429}
  .question-label{color:var(--ctm-teal);font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px}
  .question-card h3{margin:0 0 10px;font-size:20px;color:#082536}
  .question-card p{margin:0;color:#344054;line-height:1.55;font-size:14px}
  .debrief-field-list{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:14px}
  .debrief-field{background:#f8fafc;border:1px solid var(--line);border-radius:14px;padding:14px 16px;color:#344054}
  .debrief-field b{color:#082536}

  .wl-debrief-wrap{padding:28px 30px;background:linear-gradient(180deg,#fff,#fbfdfe)}
  .wl-debrief-head{display:flex;align-items:flex-start;justify-content:space-between;gap:20px;margin-bottom:18px}
  .wl-debrief-head h2{margin:0 0 12px;color:#082536;font-size:30px;letter-spacing:-.035em}
  .wl-debrief-head p{margin:0;max-width:760px;color:#465670;line-height:1.55;font-size:15px}
  .wl-required-pill{background:#eaf7e7;color:#2f6f22;border:1px solid #c9e5c2;border-radius:999px;padding:9px 14px;font-weight:900;font-size:14px;white-space:nowrap}
  .wl-question-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;margin-top:6px}
  .wl-question-card{background:#fbfff8;border:1px solid #d6eac5;border-left:0;border-radius:18px;padding:16px 18px;min-height:124px}
  .wl-question-card h3{margin:0 0 8px;color:#082536;font-size:16px;line-height:1.35}
  .wl-question-card p{margin:0;color:#465670;line-height:1.5;font-size:15px}
  .wl-step-row{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-top:14px}
  .wl-step{background:#eef8fb;border:1px solid #c9e4ea;border-radius:16px;color:#003b49;font-weight:850;line-height:1.35;padding:14px;min-height:64px;font-size:15px}


  .executive-hero{
    display:grid;
    grid-template-columns:minmax(0,1.3fr) minmax(320px,.7fr);
    gap:24px;
    align-items:stretch;
    background:
      linear-gradient(135deg,rgba(0,47,58,.98),rgba(0,74,91,.96) 50%,rgba(0,124,148,.92)),
      radial-gradient(circle at 84% 18%,rgba(118,188,67,.34),transparent 28%);
    border:1px solid rgba(255,255,255,.18);
    border-radius:34px;
    padding:46px;
    margin-bottom:24px;
    color:#fff;
    box-shadow:var(--shadow);
    position:relative;
    overflow:hidden;
  }
  .executive-hero:after{content:"";position:absolute;right:-110px;top:-140px;width:420px;height:420px;border-radius:50%;border:1px solid rgba(255,255,255,.2);box-shadow:0 0 0 46px rgba(255,255,255,.035),0 0 0 92px rgba(255,255,255,.02)}
  .executive-hero h1{font-size:clamp(40px,4.6vw,64px);line-height:1;margin:0 0 18px;letter-spacing:-.055em;position:relative;z-index:1}
  .executive-hero p{font-size:18px;line-height:1.65;color:rgba(255,255,255,.9);max-width:900px;margin:0 0 24px;position:relative;z-index:1}
  .exec-actions{display:flex;flex-wrap:wrap;gap:12px;position:relative;z-index:1}
  .exec-button{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:12px 16px;text-decoration:none;font-weight:900;border:1px solid rgba(255,255,255,.26);background:rgba(255,255,255,.14);color:#fff;backdrop-filter:blur(12px)}
  .exec-button.primary{background:#fff;color:#003b49;border-color:#fff}
  .exec-side-panel{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);border-radius:26px;padding:24px;backdrop-filter:blur(14px);position:relative;z-index:1}
  .exec-side-panel h3{margin:0 0 14px;font-size:18px;letter-spacing:-.01em}
  .exec-check{display:flex;gap:10px;align-items:flex-start;border-top:1px solid rgba(255,255,255,.14);padding:13px 0;color:rgba(255,255,255,.9);line-height:1.45}
  .exec-check:first-of-type{border-top:none;padding-top:0}
  .exec-check b{color:#fff}

  .exec-kpi-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin:0 0 24px}
  .exec-kpi{background:#fff;border:1px solid var(--line);border-radius:22px;padding:20px;box-shadow:var(--shadow-sm);position:relative;overflow:hidden}
  .exec-kpi:before{content:"";position:absolute;left:0;right:0;top:0;height:5px;background:linear-gradient(90deg,var(--ctm-teal),var(--ctm-green))}
  .exec-kpi-label{font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);font-weight:950;margin-bottom:9px}
  .exec-kpi-value{font-size:34px;line-height:1;font-weight:950;color:#082536;letter-spacing:-.05em;margin-bottom:6px}
  .exec-kpi-note{font-size:13px;color:#475467;line-height:1.4}

  .exec-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:24px}
  .exec-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:24px}
  .exec-panel{background:#fff;border:1px solid var(--line);border-radius:24px;padding:26px;box-shadow:0 8px 25px rgba(16,32,51,.06)}
  .exec-panel h2{margin:0 0 12px;color:#082536;font-size:25px;letter-spacing:-.035em}
  .exec-panel p,.exec-panel li{color:#344054;line-height:1.62}
  .exec-panel ul{margin:10px 0 0;padding-left:20px}
  .exec-panel.accent{background:linear-gradient(180deg,#fff,#f7fcfd)}
  .decision-list{display:grid;gap:12px;margin-top:14px}
  .decision-item{display:grid;grid-template-columns:130px 1fr auto;gap:14px;align-items:center;background:#f8fafc;border:1px solid var(--line);border-radius:16px;padding:14px}
  .decision-pill{display:inline-flex;justify-content:center;border-radius:999px;padding:7px 10px;font-size:12px;font-weight:900;white-space:nowrap;background:#fff4e5;color:#a15c00}
  .decision-pill.green{background:#eaf7e7;color:#2f6f22}.decision-pill.blue{background:#eef8fb;color:#00667a}
  .exec-impact-strip{display:grid;grid-template-columns:1.05fr repeat(4,1fr);gap:14px;background:#082536;color:#fff;border-radius:26px;padding:22px;margin-bottom:24px;box-shadow:var(--shadow);align-items:stretch}
